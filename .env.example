# =============================================================================
# YOUR APP'S SETTINGS
# =============================================================================
#
# This file shows what settings your app needs. To use it:
#
#   1. Make a copy of this file and name it .env
#      (On Mac/Linux: cp .env.example .env)
#      (On Windows: copy .env.example .env)
#      (Or just duplicate the file in your code editor and rename it)
#
#   2. Replace the placeholder values below with your real values
#
#   3. NEVER share your .env file or commit it to GitHub — it's your secret
#
# =============================================================================

# Your Gemini API Key
# This is like a password that lets your app talk to Google's AI.
# Get one for free: https://aistudio.google.com/apikey
#   → Sign in with Google → Click "Create API Key" → Copy the key
GEMINI_API_KEY=paste-your-key-here

# Session Secret (only needed if you add login/authentication later)
# This is a random string that keeps user sessions secure.
# You can ask your AI assistant to generate one for you.
# SESSION_SECRET=generate-a-random-string-here
