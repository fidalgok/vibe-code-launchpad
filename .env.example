# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file. It contains secrets.
# =============================================================================

# Google Gemini API Key
# Get yours free at: https://aistudio.google.com/apikey
# Click "Create API Key" → copy the key → paste it here
GEMINI_API_KEY=your-gemini-api-key-here

# Session Secret (for authentication, if you add it later)
# Generate a random string — you can ask your AI assistant to generate one
# SESSION_SECRET=generate-a-random-string-here
